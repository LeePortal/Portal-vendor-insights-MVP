{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build",
  "installCommand": "rm -f package-lock.json && npm install",
  "outputDirectory": "dist/portal-vendor-insights/browser",
