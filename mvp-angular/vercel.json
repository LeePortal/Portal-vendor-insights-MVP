{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build",
  "installCommand": "rm -f package-lock.json && npm install",
  "outputDirectory": "dist/portal-vendor-insights/browser",
  "functions": { "api/brand-performance.js": { "maxDuration": 60 }, "api/proposal-export.js": { "maxDuration": 60 }, "api/report-pdf.js": { "maxDuration": 60, "memory": 1024 }, "api/health.js": { "maxDuration": 15 }, "api/session.js": { "maxDuration": 10 } },
  "rewrites": [
    { "source": "/.well-known/oauth-authorization-server", "destination": "/api/oauth?action=meta-as" },
    { "source": "/.well-known/oauth-authorization-server/(.*)", "destination": "/api/oauth?action=meta-as" },
    { "source": "/.well-known/oauth-protected-resource", "destination": "/api/oauth?action=meta-prm" },
    { "source": "/.well-known/oauth-protected-resource/(.*)", "destination": "/api/oauth?action=meta-prm" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
